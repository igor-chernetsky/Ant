# Copy to infra/.env on the EC2 host (never commit .env)

# --- Public URLs (used by browsers and JWT issuer validation) ---
PUBLIC_BASE_URL=http://YOUR_EC2_PUBLIC_IP
API_PUBLIC_URL=http://YOUR_EC2_PUBLIC_IP/api
KEYCLOAK_PUBLIC_URL=http://YOUR_EC2_PUBLIC_IP/auth
# Hostname only (no scheme) — Keycloak KC_HOSTNAME
KEYCLOAK_HOSTNAME=YOUR_EC2_PUBLIC_IP

# --- PostgreSQL ---
POSTGRES_USER=platform
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=platform

# --- Keycloak admin (bootstrap only) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_admin

# --- Keycloak DB (same Postgres instance, separate database) ---
KEYCLOAK_DB=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change_me_keycloak_db

# --- Redis ---
REDIS_PASSWORD=change_me_redis_password

# --- MinIO (S3-compatible storage for MVP) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
S3_BUCKET=platform-uploads
S3_REGION=us-east-1

# --- App (when API/worker images are added) ---
# JWT issuer must match Keycloak realm URL exposed to the API
KEYCLOAK_REALM=construction-marketplace
KEYCLOAK_CLIENT_ID=platform-api
# For confidential API client (optional); public web uses PKCE without secret
KEYCLOAK_CLIENT_SECRET=

# NODE_ENV=production
# DATABASE_URL=postgresql://platform:change_me_strong_password@postgres:5432/platform
