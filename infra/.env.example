# Copy to infra/.env on the EC2 host (never commit .env)

# --- Public URLs (used by browsers and JWT issuer validation) ---
PUBLIC_BASE_URL=https://iabuilding.duckdns.org
API_PUBLIC_URL=https://iabuilding.duckdns.org/api
KEYCLOAK_PUBLIC_URL=https://iabuilding.duckdns.org/auth
# Hostname only (no scheme) — Keycloak KC_HOSTNAME
KEYCLOAK_HOSTNAME=iabuilding.duckdns.org
KEYCLOAK_REALM=construction-marketplace

# --- PostgreSQL ---
POSTGRES_USER=platform
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=platform

# --- Keycloak admin (bootstrap only) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_admin

# --- Keycloak DB (same Postgres instance, separate database) ---
KEYCLOAK_DB=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change_me_keycloak_db

# --- Redis ---
REDIS_PASSWORD=change_me_redis_password

# --- AWS S3 (recommended) — do NOT set S3_ENDPOINT / S3_PUBLIC_ENDPOINT ---
S3_BUCKET=ant-backet
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=AKIA...
S3_SECRET_ACCESS_KEY=...
S3_FORCE_PATH_STYLE=false
# MinIO not needed when using AWS S3 — leave COMPOSE_PROFILES unset

# --- MinIO (alternative, on EC2) — uncomment and set COMPOSE_PROFILES=full ---
# COMPOSE_PROFILES=full
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=change_me_minio_password
# S3_BUCKET=platform-uploads
# S3_REGION=us-east-1
# S3_ENDPOINT=http://minio:9000
# S3_PUBLIC_ENDPOINT=https://iabuilding.duckdns.org/storage
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=change_me_minio_password
# S3_FORCE_PATH_STYLE=true

# --- App API (optional) ---
KEYCLOAK_CLIENT_ID=platform-api
KEYCLOAK_CLIENT_SECRET=

# NODE_ENV=production
# DATABASE_URL=postgresql://platform:change_me_strong_password@postgres:5432/platform
