{
  "realm": "construction-marketplace",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "sslRequired": "external",
  "roles": {
    "realm": [
      { "name": "client", "description": "Homeowner / project owner" },
      { "name": "contractor", "description": "Contractor organization user" },
      { "name": "designer", "description": "Design company user" },
      { "name": "admin", "description": "Platform administrator" },
      { "name": "support", "description": "Customer support agent" }
    ]
  },
  "clients": [
    {
      "clientId": "platform-web",
      "name": "Platform Web",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "rootUrl": "http://localhost:3000",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://YOUR_EC2_PUBLIC_IP/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://YOUR_EC2_PUBLIC_IP"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ]
    },
    {
      "clientId": "platform-api",
      "name": "Platform API",
      "enabled": true,
      "publicClient": true,
      "bearerOnly": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "attributes": {
        "use.refresh.tokens": "true"
      }
    }
  ],
  "identityProviders": [],
  "identityProviderMappers": [],
  "components": {},
  "groups": [],
  "defaultRole": {
    "name": "default-roles-construction-marketplace",
    "description": "${role_default-roles}",
    "composite": true,
    "clientRole": false
  }
}
