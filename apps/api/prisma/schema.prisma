generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  draft
  intake
  ready_for_estimate
  estimated
  tender_ready
  in_tender
  contractor_selected
  active
  completed
}

enum ProjectType {
  renovation
  new_build
  extension
  commercial_fitout
  repair
  other
}

enum PropertyType {
  apartment
  house
  commercial
  land
  other
}

enum TagSource {
  client
  ai
}

enum DocumentStatus {
  pending
  uploaded
  deleted
}

enum DocumentCategory {
  blueprint
  photo
  specification
  estimate
  contract
  other
}

model User {
  id          String    @id @default(uuid())
  keycloakSub String    @unique @map("keycloak_sub")
  email       String?
  displayName String?   @map("display_name")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  projects    Project[]
  documents   Document[]

  @@map("users")
}

model TagGroup {
  id        String   @id @default(uuid())
  slug      String   @unique
  label     String
  sortOrder Int      @default(0) @map("sort_order")
  tags      Tag[]

  @@map("tag_groups")
}

model Tag {
  id        String       @id @default(uuid())
  slug      String       @unique
  label     String
  groupId   String?      @map("group_id")
  group     TagGroup?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  isSystem  Boolean      @default(true) @map("is_system")
  createdAt DateTime     @default(now()) @map("created_at")
  projects  ProjectTag[]

  @@index([groupId])
  @@map("tags")
}

model Project {
  id             String        @id @default(uuid())
  clientId       String        @map("client_id")
  client         User          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  projectType    ProjectType   @default(other) @map("project_type")
  propertyType   PropertyType? @map("property_type")
  district       String?
  regionCode     String        @default("TH") @map("region_code")
  status         ProjectStatus @default(draft)
  readinessScore Int           @default(0) @map("readiness_score")
  briefJson      Json?         @map("brief_json")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  tags           ProjectTag[]
  documents      Document[]
  estimates      Estimate[]

  @@index([clientId])
  @@index([projectType])
  @@map("projects")
}

model ProjectTag {
  projectId String    @map("project_id")
  tagId     String    @map("tag_id")
  source    TagSource @default(client)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([projectId, tagId])
  @@index([tagId])
  @@map("project_tags")
}

model Document {
  id           String           @id @default(uuid())
  projectId    String           @map("project_id")
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploaderId   String           @map("uploader_id")
  uploader     User             @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  originalName String           @map("original_name")
  contentType  String           @map("content_type")
  sizeBytes    Int?             @map("size_bytes")
  storageKey   String           @unique @map("storage_key")
  category     DocumentCategory @default(other)
  status       DocumentStatus   @default(pending)
  createdAt    DateTime         @default(now()) @map("created_at")
  uploadedAt   DateTime?        @map("uploaded_at")

  @@index([projectId])
  @@index([uploaderId])
  @@map("documents")
}

model Estimate {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version     Int      @default(1)
  type        String   @default("ballpark")
  currency    String   @default("THB")
  totalsJson  Json     @map("totals_json")
  linesJson   Json     @map("lines_json")
  confidence  Float
  disclaimer  String
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@map("estimates")
}
