generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  draft
  intake
  ready_for_estimate
  estimated
  tender_ready
  in_tender
  contractor_selected
  active
  completed
}

enum ProjectType {
  renovation
  new_build
  extension
  commercial_fitout
  repair
  other
}

enum PropertyType {
  apartment
  house
  commercial
  land
  other
}

enum TagSource {
  client
  ai
}

enum DocumentStatus {
  pending
  uploaded
  deleted
}

enum DocumentCategory {
  blueprint
  photo
  specification
  estimate
  contract
  other
}

enum ContractorVerificationStatus {
  pending
  awaiting_review
  verified
  suspended
  rejected
}

enum ContractorVerificationDocCategory {
  business_license
  registration
  insurance
  portfolio
  other
}

enum TenderStatus {
  draft
  collecting_participants
  open
  closed
  awarded
  cancelled
}

enum TenderInvitationStatus {
  pending
  declined
  accepted
  expired
}

enum BidStatus {
  submitted
  withdrawn
  selected
  rejected
}

enum AmendmentChangeType {
  clarification
  scope_change
  budget_change
  timeline_change
  other
}

model User {
  id          String    @id @default(uuid())
  keycloakSub String    @unique @map("keycloak_sub")
  email       String?
  displayName String?   @map("display_name")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  projects    Project[]
  documents   Document[]
  contractorProfile ContractorProfile? @relation("ContractorProfileUser")
  contractorReviews ContractorProfile[] @relation("ContractorReviewedBy")
  contractorVerificationDocuments ContractorVerificationDocument[]

  @@map("users")
}

model TagGroup {
  id        String   @id @default(uuid())
  slug      String   @unique
  label     String
  sortOrder Int      @default(0) @map("sort_order")
  tags      Tag[]

  @@map("tag_groups")
}

model Tag {
  id        String       @id @default(uuid())
  slug      String       @unique
  label     String
  groupId   String?      @map("group_id")
  group     TagGroup?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  isSystem  Boolean      @default(true) @map("is_system")
  createdAt DateTime     @default(now()) @map("created_at")
  projects  ProjectTag[]

  @@index([groupId])
  @@map("tags")
}

model Project {
  id             String        @id @default(uuid())
  clientId       String        @map("client_id")
  client         User          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  projectType    ProjectType   @default(other) @map("project_type")
  propertyType   PropertyType? @map("property_type")
  district       String?
  regionCode     String        @default("TH") @map("region_code")
  status         ProjectStatus @default(draft)
  readinessScore Int           @default(0) @map("readiness_score")
  briefJson      Json?         @map("brief_json")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  tags           ProjectTag[]
  documents      Document[]
  estimates      Estimate[]
  tender         Tender?
  amendments     ProjectAmendment[]

  @@index([clientId])
  @@index([projectType])
  @@map("projects")
}

model ProjectTag {
  projectId String    @map("project_id")
  tagId     String    @map("tag_id")
  source    TagSource @default(client)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([projectId, tagId])
  @@index([tagId])
  @@map("project_tags")
}

model Document {
  id           String           @id @default(uuid())
  projectId    String           @map("project_id")
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploaderId   String           @map("uploader_id")
  uploader     User             @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  originalName String           @map("original_name")
  contentType  String           @map("content_type")
  sizeBytes    Int?             @map("size_bytes")
  storageKey   String           @unique @map("storage_key")
  category     DocumentCategory @default(other)
  status       DocumentStatus   @default(pending)
  createdAt    DateTime         @default(now()) @map("created_at")
  uploadedAt   DateTime?        @map("uploaded_at")

  @@index([projectId])
  @@index([uploaderId])
  @@map("documents")
}

model Estimate {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version     Int      @default(1)
  type        String   @default("ballpark")
  currency    String   @default("THB")
  totalsJson  Json     @map("totals_json")
  linesJson   Json     @map("lines_json")
  confidence  Float
  disclaimer  String
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@map("estimates")
}

model ProjectAmendment {
  id           String               @id @default(uuid())
  projectId    String               @map("project_id")
  project      Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  body         String
  changeType   AmendmentChangeType? @map("change_type")
  createdAt    DateTime             @default(now()) @map("created_at")
  processedAt  DateTime?            @map("processed_at")
  aiResultJson Json?                @map("ai_result_json")

  @@index([projectId])
  @@index([projectId, processedAt])
  @@map("project_amendments")
}

model ContractorProfile {
  id                      String                       @id @default(uuid())
  userId                  String                       @unique @map("user_id")
  user                    User                         @relation("ContractorProfileUser", fields: [userId], references: [id], onDelete: Cascade)
  companyName             String?                      @map("company_name")
  regionCode              String                       @default("TH") @map("region_code")
  projectTypes            ProjectType[]                @default([]) @map("project_types")
  verificationStatus      ContractorVerificationStatus @default(pending) @map("verification_status")
  verificationComment     String?                      @map("verification_comment")
  verificationRequestedAt DateTime?                    @map("verification_requested_at")
  verificationReviewedAt  DateTime?                    @map("verification_reviewed_at")
  reviewedById            String?                      @map("reviewed_by_id")
  reviewedBy              User?                        @relation("ContractorReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt               DateTime                     @default(now()) @map("created_at")
  updatedAt               DateTime                     @updatedAt @map("updated_at")
  invitations             TenderInvitation[]
  bids                    Bid[]
  verificationDocuments   ContractorVerificationDocument[]

  @@index([regionCode])
  @@index([verificationStatus])
  @@map("contractor_profiles")
}

model ContractorVerificationDocument {
  id           String                          @id @default(uuid())
  contractorId String                          @map("contractor_id")
  contractor   ContractorProfile               @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  uploaderId   String                          @map("uploader_id")
  uploader     User                            @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  originalName String                          @map("original_name")
  contentType  String                          @map("content_type")
  sizeBytes    Int?                            @map("size_bytes")
  storageKey   String                          @unique @map("storage_key")
  category     ContractorVerificationDocCategory @default(other)
  status       DocumentStatus                  @default(pending)
  createdAt    DateTime                        @default(now()) @map("created_at")
  uploadedAt   DateTime?                       @map("uploaded_at")

  @@index([contractorId])
  @@map("contractor_verification_documents")
}

model Tender {
  id           String       @id @default(uuid())
  projectId    String       @unique @map("project_id")
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status       TenderStatus @default(draft)
  currency     String       @default("THB")
  minBids      Int          @default(1) @map("min_bids")
  opensAt      DateTime?    @map("opens_at")
  closesAt     DateTime?    @map("closes_at")
  awardedBidId String?      @unique @map("awarded_bid_id")
  awardedBid   Bid?         @relation("AwardedBid", fields: [awardedBidId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  invitations  TenderInvitation[]
  bids         Bid[]        @relation("TenderBids")

  @@index([status])
  @@map("tenders")
}

model TenderInvitation {
  id           String                 @id @default(uuid())
  tenderId     String                 @map("tender_id")
  tender       Tender                 @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  contractorId String                 @map("contractor_id")
  contractor   ContractorProfile      @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  status       TenderInvitationStatus @default(pending)
  invitedAt    DateTime               @default(now()) @map("invited_at")
  respondedAt  DateTime?              @map("responded_at")

  @@unique([tenderId, contractorId])
  @@index([contractorId])
  @@map("tender_invitations")
}

model Bid {
  id           String            @id @default(uuid())
  tenderId     String            @map("tender_id")
  tender       Tender            @relation("TenderBids", fields: [tenderId], references: [id], onDelete: Cascade)
  contractorId String            @map("contractor_id")
  contractor   ContractorProfile @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  status       BidStatus         @default(submitted)
  amount       Decimal           @db.Decimal(14, 2)
  durationDays Int?              @map("duration_days")
  termsJson    Json?             @map("terms_json")
  submittedAt  DateTime          @default(now()) @map("submitted_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  awardedTender Tender?           @relation("AwardedBid")

  @@unique([tenderId, contractorId])
  @@index([tenderId])
  @@index([contractorId])
  @@map("bids")
}
