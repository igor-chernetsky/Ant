generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  draft
  intake
  ready_for_estimate
  estimated
  in_tender
  contractor_selected
  active
  completed
}

enum ProjectType {
  renovation
  new_build
  extension
  commercial_fitout
  repair
  other
}

enum PropertyType {
  apartment
  house
  commercial
  land
  other
}

enum TagSource {
  client
  ai
}

enum DocumentStatus {
  pending
  uploaded
  deleted
}

enum DocumentCategory {
  blueprint
  photo
  specification
  estimate
  contract
  other
}

enum ContractorVerificationStatus {
  pending
  awaiting_review
  verified
  suspended
  rejected
}

enum ContractorVerificationDocCategory {
  business_license
  registration
  insurance
  owners_id
  portfolio
  other
}

enum TenderStatus {
  draft
  open
  closed
  awarded
  cancelled
}

enum BidStatus {
  clarifying
  enrolled
  submitted
  withdrawn
  selected
  rejected
}

enum BidOfferAuthor {
  client
  contractor
}

enum AmendmentChangeType {
  clarification
  scope_change
  budget_change
  timeline_change
  other
}

enum ClarificationMode {
  open_chat
  structured_qa
}

model User {
  id          String    @id @default(uuid())
  keycloakSub String    @unique @map("keycloak_sub")
  email       String?
  displayName String?   @map("display_name")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  projects    Project[]
  documents   Document[]
  contractorProfile ContractorProfile? @relation("ContractorProfileUser")
  contractorReviews ContractorProfile[] @relation("ContractorReviewedBy")
  contractorVerificationDocuments ContractorVerificationDocument[]
  bidMessages BidMessage[]
  bidOffers   BidOffer[]
  bidChatPresence BidChatPresence[]
  tenderClarificationAnswers TenderClarificationQuestion[] @relation("ClarificationAnsweredBy")
  clarificationAnswerAttachments ClarificationAnswerAttachment[]
  notificationPreferences UserNotificationPreferences?
  contractorReviewsSubmitted ContractorProjectReview[] @relation("ReviewClient")
  projectReviewAttachments ProjectReviewAttachment[]
  notificationEmailLogs   NotificationEmailLog[]

  @@map("users")
}

model UserNotificationPreferences {
  userId                 String   @id @map("user_id")
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailEnabled           Boolean  @default(true) @map("email_enabled")
  emailClientBidActivity Boolean  @default(true) @map("email_client_bid_activity")
  emailContractorUpdates Boolean  @default(true) @map("email_contractor_updates")
  emailMatchingProjects  Boolean  @default(true) @map("email_matching_projects")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("user_notification_preferences")
}

enum NotificationEmailKind {
  client_bid_enrolled
  client_bid_submitted
  client_tender_deadline_reached
  contractor_counter_offer
  contractor_bid_message
  contractor_bid_selected
  contractor_bid_rejected
  contractor_project_awarded
  contractor_matching_project
  contractor_tender_opened
}

model NotificationEmailLog {
  id        String                @id @default(uuid())
  userId    String                @map("user_id")
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      NotificationEmailKind
  projectId String?               @map("project_id")
  sentAt    DateTime              @default(now()) @map("sent_at")

  @@index([userId, kind, sentAt])
  @@map("notification_email_logs")
}

model TagGroup {
  id        String   @id @default(uuid())
  slug      String   @unique
  label     String
  sortOrder Int      @default(0) @map("sort_order")
  tags      Tag[]

  @@map("tag_groups")
}

model Tag {
  id        String       @id @default(uuid())
  slug      String       @unique
  label     String
  groupId   String?      @map("group_id")
  group     TagGroup?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  isSystem  Boolean      @default(true) @map("is_system")
  createdAt DateTime     @default(now()) @map("created_at")
  projects  ProjectTag[]

  @@index([groupId])
  @@map("tags")
}

model Project {
  id             String        @id @default(uuid())
  clientId       String        @map("client_id")
  client         User          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  projectType    ProjectType   @default(other) @map("project_type")
  propertyType   PropertyType? @map("property_type")
  district       String?
  locationRegionSlug String   @default("bangkok") @map("location_region_slug")
  locationAreaSlug   String?  @map("location_area_slug")
  locationNote       String?  @map("location_note")
  regionCode     String        @default("TH") @map("region_code")
  status         ProjectStatus @default(draft)
  isHidden       Boolean       @default(false) @map("is_hidden")
  readinessScore Int           @default(0) @map("readiness_score")
  briefJson      Json?         @map("brief_json")
  clarificationMode ClarificationMode @default(open_chat) @map("clarification_mode")
  clarificationSummary String?  @map("clarification_summary") @db.Text
  scopeSummary         String?  @map("scope_summary") @db.Text
  tenderContractTermsJson Json? @map("tender_contract_terms_json")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  tags           ProjectTag[]
  documents      Document[]
  estimates      Estimate[]
  tender         Tender?
  amendments     ProjectAmendment[]
  contractorReview ContractorProjectReview?
  reviewAttachments ProjectReviewAttachment[]

  @@index([clientId])
  @@index([clientId, isHidden])
  @@index([projectType])
  @@index([locationRegionSlug])
  @@map("projects")
}

model ProjectTag {
  projectId String    @map("project_id")
  tagId     String    @map("tag_id")
  source    TagSource @default(client)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([projectId, tagId])
  @@index([tagId])
  @@map("project_tags")
}

model Document {
  id           String           @id @default(uuid())
  projectId    String           @map("project_id")
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploaderId   String           @map("uploader_id")
  uploader     User             @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  originalName String           @map("original_name")
  contentType  String           @map("content_type")
  sizeBytes    Int?             @map("size_bytes")
  storageKey   String           @unique @map("storage_key")
  category     DocumentCategory @default(other)
  status       DocumentStatus   @default(pending)
  createdAt    DateTime         @default(now()) @map("created_at")
  uploadedAt   DateTime?        @map("uploaded_at")

  @@index([projectId])
  @@index([uploaderId])
  @@map("documents")
}

model Estimate {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version     Int      @default(1)
  type        String   @default("ballpark")
  currency    String   @default("THB")
  totalsJson  Json     @map("totals_json")
  linesJson   Json     @map("lines_json")
  confidence  Float
  disclaimer  String
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@map("estimates")
}

model ProjectAmendment {
  id           String               @id @default(uuid())
  projectId    String               @map("project_id")
  project      Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  body         String
  changeType   AmendmentChangeType? @map("change_type")
  createdAt    DateTime             @default(now()) @map("created_at")
  processedAt  DateTime?            @map("processed_at")
  aiResultJson Json?                @map("ai_result_json")

  @@index([projectId])
  @@index([projectId, processedAt])
  @@map("project_amendments")
}

model ContractorProfile {
  id                      String                       @id @default(uuid())
  userId                  String                       @unique @map("user_id")
  user                    User                         @relation("ContractorProfileUser", fields: [userId], references: [id], onDelete: Cascade)
  companyName             String?                      @map("company_name")
  regionCode              String                       @default("TH") @map("region_code")
  serviceLocationsJson    Json                         @default("[{\"regionSlug\":\"bangkok\"}]") @map("service_locations_json")
  projectTypes            ProjectType[]                @default([]) @map("project_types")
  tagSlugs                String[]                     @default([]) @map("tag_slugs")
  verificationStatus      ContractorVerificationStatus @default(pending) @map("verification_status")
  verificationComment     String?                      @map("verification_comment")
  verificationRequestedAt DateTime?                    @map("verification_requested_at")
  verificationReviewedAt  DateTime?                    @map("verification_reviewed_at")
  reviewedById            String?                      @map("reviewed_by_id")
  reviewedBy              User?                        @relation("ContractorReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt               DateTime                     @default(now()) @map("created_at")
  updatedAt               DateTime                     @updatedAt @map("updated_at")
  bids                    Bid[]
  verificationDocuments   ContractorVerificationDocument[]
  portfolioItems          ContractorPortfolioItem[]
  projectReviews          ContractorProjectReview[]

  @@index([regionCode])
  @@index([verificationStatus])
  @@map("contractor_profiles")
}

model ContractorVerificationDocument {
  id           String                          @id @default(uuid())
  contractorId String                          @map("contractor_id")
  contractor   ContractorProfile               @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  uploaderId   String                          @map("uploader_id")
  uploader     User                            @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  originalName String                          @map("original_name")
  contentType  String                          @map("content_type")
  sizeBytes    Int?                            @map("size_bytes")
  storageKey   String                          @unique @map("storage_key")
  category     ContractorVerificationDocCategory @default(other)
  status       DocumentStatus                  @default(pending)
  createdAt    DateTime                        @default(now()) @map("created_at")
  uploadedAt   DateTime?                       @map("uploaded_at")

  @@index([contractorId])
  @@map("contractor_verification_documents")
}

model ContractorPortfolioItem {
  id                  String            @id @default(uuid())
  contractorId        String            @map("contractor_id")
  contractor          ContractorProfile @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  title               String
  description         String?           @db.Text
  originalName        String            @map("original_name")
  contentType         String            @map("content_type")
  sizeBytes           Int?              @map("size_bytes")
  storageKey          String            @unique @map("storage_key")
  thumbnailStorageKey String?           @unique @map("thumbnail_storage_key")
  sortOrder           Int               @default(0) @map("sort_order")
  status              DocumentStatus    @default(pending)
  createdAt           DateTime          @default(now()) @map("created_at")
  uploadedAt          DateTime?         @map("uploaded_at")

  @@index([contractorId, sortOrder])
  @@map("contractor_portfolio_items")
}

model Tender {
  id           String       @id @default(uuid())
  projectId    String       @unique @map("project_id")
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status       TenderStatus @default(draft)
  currency     String       @default("THB")
  minBids      Int          @default(1) @map("min_bids")
  opensAt      DateTime?    @map("opens_at")
  closesAt     DateTime?    @map("closes_at")
  deadlineNotifiedAt DateTime? @map("deadline_notified_at")
  awardedBidId String?      @unique @map("awarded_bid_id")
  awardedBid   Bid?         @relation("AwardedBid", fields: [awardedBidId], references: [id], onDelete: SetNull)
  bidAnalysisJson Json?       @map("bid_analysis_json")
  defaultCostBreakdown Json?  @map("default_cost_breakdown")
  nextContenderNumber Int     @default(1) @map("next_contender_number")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  bids         Bid[]        @relation("TenderBids")
  clarificationQuestions TenderClarificationQuestion[]

  @@index([status])
  @@map("tenders")
}

model Bid {
  id           String            @id @default(uuid())
  tenderId     String            @map("tender_id")
  tender       Tender            @relation("TenderBids", fields: [tenderId], references: [id], onDelete: Cascade)
  contractorId String            @map("contractor_id")
  contractor   ContractorProfile @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  status       BidStatus         @default(clarifying)
  amount       Decimal?          @db.Decimal(14, 2)
  durationDays Int?              @map("duration_days")
  termsJson    Json?             @map("terms_json")
  contenderNumber Int?           @map("contender_number")
  enrolledAt   DateTime?         @map("enrolled_at")
  submittedAt  DateTime?         @map("submitted_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  awardedTender Tender?          @relation("AwardedBid")
  messages     BidMessage[]
  offers       BidOffer[]
  chatPresence BidChatPresence[]
  clarificationSubmission BidClarificationSubmission?
  projectReview           ContractorProjectReview?

  @@unique([tenderId, contractorId])
  @@index([tenderId])
  @@index([contractorId])
  @@map("bids")
}

model BidMessage {
  id        String   @id @default(uuid())
  bidId     String   @map("bid_id")
  bid       Bid      @relation(fields: [bidId], references: [id], onDelete: Cascade)
  authorId  String   @map("author_id")
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([bidId])
  @@map("bid_messages")
}

model BidChatPresence {
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bidId      String   @map("bid_id")
  bid        Bid      @relation(fields: [bidId], references: [id], onDelete: Cascade)
  lastSeenAt DateTime @map("last_seen_at")

  @@id([userId, bidId])
  @@index([bidId, lastSeenAt])
  @@map("bid_chat_presence")
}

model BidOffer {
  id           String          @id @default(uuid())
  bidId        String          @map("bid_id")
  bid          Bid             @relation(fields: [bidId], references: [id], onDelete: Cascade)
  authorRole   BidOfferAuthor  @map("author_role")
  authorId     String          @map("author_id")
  author       User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  amount       Decimal         @db.Decimal(14, 2)
  durationDays Int?            @map("duration_days")
  termsJson    Json?           @map("terms_json")
  note         String?
  createdAt    DateTime        @default(now()) @map("created_at")

  @@index([bidId])
  @@map("bid_offers")
}

model BidClarificationSubmission {
  id          String   @id @default(uuid())
  bidId       String   @unique @map("bid_id")
  bid         Bid      @relation(fields: [bidId], references: [id], onDelete: Cascade)
  questions   Json
  submittedAt DateTime @default(now()) @map("submitted_at")

  @@map("bid_clarification_submissions")
}

model TenderClarificationQuestion {
  id           String    @id @default(uuid())
  tenderId     String    @map("tender_id")
  tender       Tender    @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  questionText String    @map("question_text")
  sortOrder    Int       @default(0) @map("sort_order")
  answer       String?   @db.Text
  answeredAt   DateTime? @map("answered_at")
  answeredById String?   @map("answered_by_id")
  answeredBy   User?     @relation("ClarificationAnsweredBy", fields: [answeredById], references: [id], onDelete: SetNull)
  sourceBidIds String[]  @default([]) @map("source_bid_ids")
  attachments  ClarificationAnswerAttachment[]
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([tenderId, sortOrder])
  @@map("tender_clarification_questions")
}

model ClarificationAnswerAttachment {
  id           String                      @id @default(uuid())
  questionId   String                      @map("question_id")
  question     TenderClarificationQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  uploaderId   String                      @map("uploader_id")
  uploader     User                        @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  originalName String                      @map("original_name")
  contentType  String                      @map("content_type")
  sizeBytes    Int?                        @map("size_bytes")
  storageKey   String                      @unique @map("storage_key")
  status       DocumentStatus              @default(pending)
  createdAt    DateTime                    @default(now()) @map("created_at")
  uploadedAt   DateTime?                   @map("uploaded_at")

  @@index([questionId])
  @@map("clarification_answer_attachments")
}

model ContractorProjectReview {
  id           String            @id @default(uuid())
  projectId    String            @unique @map("project_id")
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientId     String            @map("client_id")
  client       User              @relation("ReviewClient", fields: [clientId], references: [id], onDelete: Cascade)
  contractorId String            @map("contractor_id")
  contractor   ContractorProfile @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  bidId        String            @unique @map("bid_id")
  bid          Bid               @relation(fields: [bidId], references: [id], onDelete: Cascade)
  comment      String?           @db.Text
  ratingsJson  Json              @map("ratings_json")
  createdAt    DateTime          @default(now()) @map("created_at")
  attachments  ProjectReviewAttachment[]

  @@index([contractorId])
  @@index([clientId])
  @@map("contractor_project_reviews")
}

model ProjectReviewAttachment {
  id           String                   @id @default(uuid())
  projectId    String                   @map("project_id")
  project      Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientId     String                   @map("client_id")
  client       User                     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  reviewId     String?                  @map("review_id")
  review       ContractorProjectReview? @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  originalName String                   @map("original_name")
  contentType  String                   @map("content_type")
  sizeBytes    Int                      @map("size_bytes")
  storageKey   String                   @unique @map("storage_key")
  status       DocumentStatus           @default(pending)
  uploadedAt   DateTime?                @map("uploaded_at")
  createdAt    DateTime                 @default(now()) @map("created_at")

  @@index([projectId])
  @@index([reviewId])
  @@map("project_review_attachments")
}
