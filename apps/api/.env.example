DATABASE_URL=postgresql://platform:change_me@localhost:5432/platform
KEYCLOAK_ISSUER=https://iabuilding.duckdns.org/auth/realms/construction-marketplace
KEYCLOAK_JWKS_URI=https://iabuilding.duckdns.org/auth/realms/construction-marketplace/protocol/openid-connect/certs
# Public web app URL (notification email links)
WEB_APP_URL=https://ant-eta-seven.vercel.app

# SMTP (same credentials as Keycloak / Vercel — transactional notifications)
SMTP_HOST=email-smtp.ap-southeast-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@antconstruction.xyz
SMTP_FROM_NAME=Ant Construction

# OpenAI — project intake (optional; uses rule-based fallback if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
