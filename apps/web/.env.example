# Copy to .env.local for local development

NEXT_PUBLIC_KEYCLOAK_URL=https://iabuilding.duckdns.org/auth
NEXT_PUBLIC_KEYCLOAK_REALM=construction-marketplace
NEXT_PUBLIC_API_URL=https://iabuilding.duckdns.org/api
NEXT_PUBLIC_APP_URL=https://ant-eta-seven.vercel.app

# Server-only — never use NEXT_PUBLIC_ prefix for the secret
KEYCLOAK_BFF_CLIENT_ID=platform-bff
KEYCLOAK_BFF_CLIENT_SECRET=set-in-keycloak-admin-credentials-tab

# Sign up (creates users via Keycloak Admin API) — same admin as Keycloak bootstrap on EC2
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=your-keycloak-admin-password-from-infra-env

# Local dev only — skip email verification when Keycloak SMTP is not configured
# SKIP_EMAIL_VERIFICATION=true
